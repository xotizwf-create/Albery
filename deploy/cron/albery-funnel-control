SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
CRON_TZ=Europe/Moscow

# Контроль воронок Albery (задача владельца 16.07). Две автоматизации:
# 1) Пн/Ср/Пт 09:00 — проверка + снимок состояния в БД (никому не шлёт, копит данные для сравнения).
0 9 * * 1,3,5 root cd /var/www/albery && /var/www/albery/.venv/bin/python /var/www/albery/funnel_control.py check >> /var/log/albery/funnel-control.log 2>&1
# 2) Среда 15:00 — сводка по воронке + рекомендации отдельной задачей владельцу (Артур/Наталья), перед встречей руководителей (чт).
0 15 * * 3 root cd /var/www/albery && /var/www/albery/.venv/bin/python /var/www/albery/funnel_control.py summary >> /var/log/albery/funnel-control.log 2>&1
