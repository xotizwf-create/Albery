BITRIX_WEBHOOK_BASE=https://yourcompany.bitrix24.ru/rest/1/xxxxxxxxxxxx/
FLASK_SECRET_KEY=replace-with-random-string
BITRIX_EXPORT_MODE=audit
BITRIX_REQUEST_DELAY=0.05
BITRIX_LOOKBACK_DAYS=30

# PostgreSQL connection for the new schema.
# Example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/employee_analytics
DATABASE_URL=
# Optional admin/owner connection used only by scripts/ensure_postgres.py for DDL migrations.
DATABASE_ADMIN_URL=

# Optional protection for public MCP endpoint.
# Use https://host/mcp/<this-secret> in Claude Web custom connector,
# or send Authorization: Bearer <this-secret>.
# HTTP MCP is disabled without this secret unless MCP_ALLOW_UNAUTHENTICATED=1.
MCP_SHARED_SECRET=
MCP_ALLOW_UNAUTHENTICATED=0

# LLM provider (OpenAI-compatible endpoint or Google AI Studio)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OWNER_DAILY_MODEL=gemini-2.0-flash
OWNER_WEEKLY_MODEL=gemini-2.5-flash
OPENAI_CONTRACT_MODEL=gpt-4.1-mini
OPENAI_API_MODE=responses
OPENAI_TIMEOUT_SECONDS=120

# Optional explicit Google variables (used as fallbacks)
GOOGLE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Google Drive -> "О компании" sync through Google Apps Script web app.
GOOGLE_APPS_SCRIPT_SYNC_URL=
GOOGLE_APPS_SCRIPT_SYNC_TOKEN=
GOOGLE_DRIVE_COMPANY_ROOT_NAME=Google Drive

# Google Drive call transcripts sync. Reads only transcript.txt files.
# Optional: if empty, the backend uses GOOGLE_APPS_SCRIPT_SYNC_URL and GOOGLE_APPS_SCRIPT_SYNC_TOKEN.
GOOGLE_CALLS_APPS_SCRIPT_SYNC_URL=
GOOGLE_CALLS_APPS_SCRIPT_SYNC_TOKEN=
